# SocialPredict Backend environment configuration
# This file MUST be named .env.dev and placed in the /backend folder for manual development

# Database Configuration (Neon DB)
DB_HOST=ep-dawn-brook-am8i54cy-pooler.c-5.us-east-1.aws.neon.tech
POSTGRES_USER=socialpredict
POSTGRES_PASSWORD=npg_Aj1lOsYH6VfZ
POSTGRES_DATABASE=socialpredict_db
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require

# Server Configuration
BACKEND_PORT=8080

# Security and CORS
# Allows the frontend (Vite) to communicate with the backend
CORS_ENABLED=true
CORS_ALLOW_ORIGINS=http://localhost:5173
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=true

# JWT signing key — CHANGE THIS to a long random string (e.g. openssl rand -hex 32) before production
JWT_SIGNING_KEY=CHANGE_ME_use_openssl_rand_hex_32_before_going_to_prod

# Initial Admin Password (used if seeding a new database)
# CHANGE THIS before going to production!
ADMIN_PASSWORD=password
